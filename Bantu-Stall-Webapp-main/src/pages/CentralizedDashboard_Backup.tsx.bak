import React, { useState, useEffect, useMemo, useCallback } from 'react';
import { useAuth } from '@/hooks/useAuth';
import { useRequireAuth } from '@/hooks/useRequireAuth';
import { useNavigate, useLocation } from 'react-router-dom';
import { motion, AnimatePresence } from 'framer-motion';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';
import { Badge } from '@/components/ui/badge';
import { Progress } from '@/components/ui/progress';
import { Input } from '@/components/ui/input';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Alert, AlertDescription } from '@/components/ui/alert';
import { Separator } from '@/components/ui/separator';
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from '@/components/ui/tooltip';
import { supabase } from '@/integrations/supabase/client';
import Navbar from '@/components/Navbar';
import Footer from '@/components/Footer';
import { 
  Home, Users, BookOpen, Mountain, Building2, Settings, Bell, Search,
  Plane, Calendar, Star, MapPin, Globe, TrendingUp, Award, Activity,
  MessageSquare, Target, Clock, DollarSign, BarChart3, Coffee, Sparkles,
  Plus, Filter, Eye, Edit, Trash2, User, LogOut, Heart, Bookmark, 
  Camera, Compass, Network, Mail, Menu, X, ChevronRight, ChevronLeft,
  FileText, Package, Briefcase, Info, PlusCircle, Zap, Brain,
  GraduationCap, Maximize2, Minimize2, MoreVertical, Loader2, RefreshCw
} from 'lucide-react';

interface UserProfile {
  user_type?: string;
  onboarding_completed?: boolean;
  default_dashboard?: string;
  last_active?: string;
  full_name?: string;
  avatar_url?: string;
  company?: string;
  location?: string;
}

interface NavigationItem {
  id: string;
  title: string;
  icon: React.ElementType;
  path?: string;
  badge?: string | number;
  children?: NavigationItem[];
  description?: string;
  color?: string;
}

interface ActivityItem {
  id: string;
  type: 'quotation' | 'booking' | 'application' | 'property' | 'message';
  title: string;
  description: string;
  created_at: string;
  status: string;
  amount?: number;
  metadata?: Record<string, unknown>;
}

interface NotificationItem {
  id: string;
  title: string;
  message: string;
  type: 'info' | 'success' | 'warning' | 'error';
  created_at: string;
  read: boolean;
  action_url?: string;
}

interface DashboardStats {
  totalQuotations: number;
  activeBookings: number;
  totalRevenue: number;
  countriesExplored: number;
  learningProgress: number;
  communityConnections: number;
  properties: number;
  applications: number;
  unreadMessages: number;
  completedCourses: number;
}

interface RealTimeData {
  stats: DashboardStats;
  recentActivity: ActivityItem[];
  notifications: NotificationItem[];
  isLoading: boolean;
  lastUpdated: Date;
}

const CentralizedDashboard = () => {
  const { user } = useRequireAuth();
  const navigate = useNavigate();
  const location = useLocation();
  
  // State management
  const [userProfile, setUserProfile] = useState<UserProfile | null>(null);
  const [activeSection, setActiveSection] = useState('overview');
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
  const [expandedItems, setExpandedItems] = useState<string[]>(['travel', 'business']);
  const [searchQuery, setSearchQuery] = useState('');
  const [realTimeData, setRealTimeData] = useState<RealTimeData>({
    stats: {
      totalQuotations: 0,
      activeBookings: 0,
      totalRevenue: 0,
      countriesExplored: 0,
      learningProgress: 0,
      communityConnections: 0,
      properties: 0,
      applications: 0,
      unreadMessages: 0,
      completedCourses: 0
    },
    recentActivity: [],
    notifications: [],
    isLoading: true,
    lastUpdated: new Date()
  });
  const [refreshing, setRefreshing] = useState(false);

  // Real-time data fetching function
  const fetchDashboardData = useCallback(async (showRefreshIndicator = false) => {
    if (!user?.id) return;

    try {
      if (showRefreshIndicator) setRefreshing(true);
      
      setRealTimeData(prev => ({ ...prev, isLoading: !showRefreshIndicator }));

      // Fetch user profile from auth metadata and database
      const userMetadata = user.user_metadata;
      const profileData: UserProfile = {
        user_type: userMetadata?.user_type,
        onboarding_completed: userMetadata?.onboarding_completed,
        default_dashboard: userMetadata?.default_dashboard,
        last_active: userMetadata?.last_active,
        full_name: userMetadata?.full_name,
        avatar_url: userMetadata?.avatar_url,
        company: userMetadata?.company,
        location: userMetadata?.location
      };
      setUserProfile(profileData);

      // Parallel data fetching for real-time stats
      const [
        quotationsResponse,
        propertyListingsResponse,
        horoApplicationsResponse,
        clientsResponse
      ] = await Promise.allSettled([
        // Fetch quotation requests
        supabase
          .from('quotation_requests')
          .select('*')
          .eq('user_id', user.id)
          .order('created_at', { ascending: false }),
        
        // Fetch property listings
        supabase
          .from('property_listings')
          .select('*')
          .eq('user_id', user.id),
        
        // Fetch applications
        supabase
          .from('horo_applications')
          .select('*')
          .eq('user_id', user.id),
        
        // Fetch clients (for service providers)
        supabase
          .from('clients')
          .select('*')
          .eq('user_id', user.id)
      ]);

      // Process quotations data
      const quotations = quotationsResponse.status === 'fulfilled' ? quotationsResponse.value.data || [] : [];
      const properties = propertyListingsResponse.status === 'fulfilled' ? propertyListingsResponse.value.data || [] : [];
      const applications = horoApplicationsResponse.status === 'fulfilled' ? horoApplicationsResponse.value.data || [] : [];
      const clients = clientsResponse.status === 'fulfilled' ? clientsResponse.value.data || [] : [];

      // Calculate dynamic stats with correct field names
      const stats: DashboardStats = {
        totalQuotations: quotations.length,
        activeBookings: quotations.filter(q => q.status === 'approved' || q.status === 'confirmed').length,
        totalRevenue: quotations
          .filter(q => q.status === 'approved' || q.status === 'confirmed')
          .reduce((sum, q) => sum + (parseFloat(q.budget_range?.split('-')[1] || '0') || 0), 0),
        countriesExplored: new Set(quotations.map(q => q.location).filter(Boolean)).size,
        learningProgress: Math.min(100, quotations.length * 5), // 5% per quotation
        communityConnections: clients.length,
        properties: properties.length,
        applications: applications.length,
        unreadMessages: quotations.filter(q => q.status === 'pending').length,
        completedCourses: Math.floor(quotations.length / 2) // 1 course per 2 quotations
      };

      // Build recent activity from all data sources with correct field names
      const recentActivity: ActivityItem[] = [
        ...quotations.slice(0, 5).map(q => ({
          id: q.id,
          type: 'quotation' as const,
          title: `Quotation Request #${q.id.slice(-6)}`,
          description: `${q.service_requested || 'Service'} in ${q.location || 'Africa'}`,
          created_at: q.created_at,
          status: q.status,
          amount: parseFloat(q.budget_range?.split('-')[1] || '0') || 0,
          metadata: { destination: q.location, service: q.service_requested }
        })),
        ...applications.slice(0, 3).map(app => ({
          id: app.id,
          type: 'application' as const,
          title: 'Service Provider Application',
          description: `Application for ${app.company_name || 'Business'}`,
          created_at: app.created_at,
          status: app.status || 'pending',
          metadata: { business_name: app.company_name, business_type: app.job_title }
        })),
        ...properties.slice(0, 3).map(prop => ({
          id: prop.id,
          type: 'property' as const,
          title: `Property: ${prop.property_type || 'Listing'}`,
          description: `${prop.property_type} in ${prop.location}`,
          created_at: prop.created_at,
          status: prop.status || 'active',
          metadata: { location: prop.location, type: prop.property_type }
        }))
      ].sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).slice(0, 10);

      // Generate dynamic notifications with correct field names
      const notifications: NotificationItem[] = [
        ...quotations.filter(q => q.status === 'pending').map(q => ({
          id: `quote-${q.id}`,
          title: 'Quotation Pending',
          message: `Your quotation for ${q.service_requested || 'service'} is being reviewed`,
          type: 'info' as const,
          created_at: q.created_at,
          read: false,
          action_url: `/quotations`
        })),
        ...quotations.filter(q => q.status === 'approved').slice(0, 3).map(q => ({
          id: `approved-${q.id}`,
          title: 'Quotation Approved!',
          message: `Your ${q.service_requested || 'service'} quotation has been approved`,
          type: 'success' as const,
          created_at: q.updated_at || q.created_at,
          read: false,
          action_url: `/quotations`
        }))
      ].slice(0, 10);

      // Update state with real data
      setRealTimeData({
        stats,
        recentActivity,
        notifications,
        isLoading: false,
        lastUpdated: new Date()
      });

    } catch (error) {
      console.error('Error fetching dashboard data:', error);
      setRealTimeData(prev => ({ ...prev, isLoading: false }));
    } finally {
      setRefreshing(false);
    }
  }, [user]);

  // Initial data load
  useEffect(() => {
    fetchDashboardData();
  }, [fetchDashboardData]);

  // Auto-refresh every 30 seconds
  useEffect(() => {
    const interval = setInterval(() => {
      fetchDashboardData(true);
    }, 30000);

    return () => clearInterval(interval);
  }, [fetchDashboardData]);

  // Handle section changes from URL
  useEffect(() => {
    const urlParams = new URLSearchParams(location.search);
    const section = urlParams.get('section');
    if (section && section !== activeSection) {
      setActiveSection(section);
    }
  }, [location.search, activeSection]);
    const baseItems: NavigationItem[] = [
      {
        id: 'overview',
        title: 'Overview',
        icon: Home,
        description: 'Dashboard overview and analytics'
      },
      {
        id: 'travel',
        title: 'Travel & Explore',
        icon: Plane,
        children: [
          {
            id: 'explorer',
            title: 'Travel Explorer',
            icon: Compass,
            badge: realTimeData ? `${realTimeData.stats.countriesExplored}` : '0',
            description: 'Discover African destinations and experiences'
          },
          {
            id: 'bookings',
            title: 'My Bookings',
            icon: Calendar,
            badge: realTimeData ? `${realTimeData.stats.activeBookings}` : '0',
            description: 'Track your bookings and itineraries'
          },
          {
            id: 'favorites',
            title: 'Favorites',
            icon: Heart,
            description: 'Your saved destinations and experiences'
          },
          {
            id: 'countries',
            title: 'Countries',
            icon: Globe,
            path: '/countries',
            description: 'Explore all African countries'
          }
        ]
      },
      {
        id: 'learning',
        title: 'Learning Hub',
        icon: BookOpen,
        children: [
          {
            id: 'courses',
            title: 'My Courses',
            icon: GraduationCap,
            badge: 'Active',
            description: 'Educational content and skill development'
          },
          {
            id: 'progress',
            title: 'Progress Tracking',
            icon: Target,
            badge: realTimeData ? `${realTimeData.stats.learningProgress}%` : '0%',
            description: 'Monitor your learning achievements'
          },
          {
            id: 'certificates',
            title: 'Certificates',
            icon: Award,
            badge: '5',
            description: 'Your earned certificates and achievements'
          }
        ]
      },
      {
        id: 'community',
        title: 'Community',
        icon: Users,
        children: [
          {
            id: 'members',
            title: 'Member Directory',
            icon: Users,
            badge: realTimeData ? `${realTimeData.stats.communityConnections}` : '0',
            description: 'Connect with fellow travelers and professionals'
          },
          {
            id: 'messages',
            title: 'Messages',
            icon: MessageSquare,
            badge: realTimeData ? realTimeData.notifications.filter(n => !n.read).length.toString() : '0',
            description: 'Community discussions and private messages'
          },
          {
            id: 'events',
            title: 'Events & Meetups',
            icon: Calendar,
            description: 'Join community events and networking sessions'
          }
        ]
      },
      {
        id: 'tools',
        title: 'Tools & Services',
        icon: Zap,
        children: [
          {
            id: 'quotations',
            title: 'Quotations',
            icon: FileText,
            badge: 'Active',
            description: 'Request and manage service quotations'
          },
          {
            id: 'profile',
            title: 'My Profile',
            icon: User,
            path: '/profile',
            description: 'Manage your account and preferences'
          },
          {
            id: 'settings',
            title: 'Settings',
            icon: Settings,
            description: 'Configure your dashboard and notifications'
          }
        ]
      }
    ];

    // Add user-specific items based on user type
    if (userProfile?.user_type === 'corporate') {
      baseItems.splice(3, 0, {
        id: 'retreats',
        title: 'Corporate Retreats',
        icon: Mountain,
        children: [
          {
            id: 'retreat-planning',
            title: 'Plan New Retreat',
            icon: PlusCircle,
            description: 'Design memorable corporate retreats in Africa'
          },
          {
            id: 'retreat-bookings',
            title: 'Active Retreats',
            icon: Calendar,
            badge: '3',
            description: 'Manage current and upcoming retreats'
          },
          {
            id: 'team-analytics',
            title: 'Team Analytics',
            icon: BarChart3,
            description: 'Track engagement and ROI metrics'
          },
          {
            id: 'budget-management',
            title: 'Budget Management',
            icon: DollarSign,
            description: 'Monitor expenses and budget allocation'
          }
        ]
      });
    }

    if (userProfile?.user_type === 'service_provider') {
      baseItems.push({
        id: 'business',
        title: 'Business Management',
        icon: Building2,
        children: [
          {
            id: 'provider-dashboard',
            title: 'Provider Dashboard',
            icon: BarChart3,
            badge: 'Live',
            description: 'Monitor your business performance'
          },
          {
            id: 'client-management',
            title: 'Client Management',
            icon: Users,
            path: '/clients',
            description: 'Manage client relationships and communications'
          },
          {
            id: 'services',
            title: 'Service Listings',
            icon: Package,
            path: '/products',
            description: 'Update your services and pricing'
          },
          {
            id: 'revenue-analytics',
            title: 'Revenue Analytics',
            icon: TrendingUp,
            description: 'Track earnings and financial insights'
          }
        ]
      });
    }

    return baseItems;
  }, [realTimeData]); // Add dependency

  // All other hooks and callbacks
  const toggleExpanded = useCallback((itemId: string) => {
          },
          {
            id: 'quotations',
            title: 'My Quotations',
            icon: FileText,
            badge: stats.totalQuotations > 0 ? stats.totalQuotations : undefined,
            description: 'Track quotation requests',
            color: 'text-bantu-orange'
          },
          {
            id: 'bookings',
            title: 'Active Bookings',
            icon: Calendar,
            badge: stats.activeBookings > 0 ? stats.activeBookings : undefined,
            description: 'Manage your bookings',
            color: 'text-purple-600'
          },
          {
            id: 'countries',
            title: 'Countries Guide',
            icon: Globe,
            path: '/countries',
            description: 'Explore all African countries',
            color: 'text-emerald-600'
          }
        ]
      },
      {
        id: 'learning',
        title: 'Mafunzo (Learning)',
        icon: BookOpen,
        color: 'text-bantu-yellow',
        children: [
          {
            id: 'courses',
            title: 'My Courses',
            icon: GraduationCap,
            badge: stats.completedCourses > 0 ? `${stats.completedCourses} completed` : 'Start learning',
            description: 'Educational content and skills',
            color: 'text-indigo-600'
          },
          {
            id: 'progress',
            title: 'Learning Progress',
            icon: Target,
            badge: `${stats.learningProgress}%`,
            description: 'Track your achievements',
            color: 'text-green-600'
          },
          {
            id: 'certificates',
            title: 'Certificates',
            icon: Award,
            badge: Math.floor(stats.completedCourses / 2),
            description: 'Your earned certificates',
            color: 'text-yellow-600'
          }
        ]
      },
      {
        id: 'community',
        title: 'Abantu (Community)',
        icon: Users,
        color: 'text-pink-600',
        children: [
          {
            id: 'members',
            title: 'Member Network',
            icon: Network,
            badge: stats.communityConnections > 0 ? stats.communityConnections : 'Connect now',
            description: 'Connect with fellow travelers',
            color: 'text-blue-600'
          },
          {
            id: 'messages',
            title: 'Messages',
            icon: MessageSquare,
            badge: stats.unreadMessages > 0 ? stats.unreadMessages : undefined,
            description: 'Community discussions',
            color: 'text-cyan-600'
          },
          {
            id: 'events',
            title: 'Events & Meetups',
            icon: Calendar,
            description: 'Join community events',
            color: 'text-purple-600'
          }
        ]
      }
    ];

    // Add corporate retreat section for corporate users
    if (userProfile?.user_type === 'corporate') {
      baseItems.splice(2, 0, {
        id: 'retreats',
        title: 'Corporate Retreats',
        icon: Mountain,
        color: 'text-bantu-orange',
        children: [
          {
            id: 'retreat-planning',
            title: 'Plan New Retreat',
            icon: PlusCircle,
            description: 'Design memorable corporate retreats',
            color: 'text-emerald-600'
          },
          {
            id: 'retreat-bookings',
            title: 'Active Retreats',
            icon: Calendar,
            badge: stats.activeBookings,
            description: 'Manage current retreats',
            color: 'text-blue-600'
          },
          {
            id: 'team-analytics',
            title: 'Team Analytics',
            icon: BarChart3,
            description: 'Track engagement and ROI',
            color: 'text-purple-600'
          },
          {
            id: 'budget-management',
            title: 'Budget Tracking',
            icon: DollarSign,
            badge: stats.totalRevenue > 0 ? `$${(stats.totalRevenue / 1000).toFixed(1)}k` : undefined,
            description: 'Monitor expenses and budgets',
            color: 'text-green-600'
          }
        ]
      });
    }

    // Add business management for service providers
    if (userProfile?.user_type === 'service_provider') {
      baseItems.push({
        id: 'business',
        title: 'Business Hub',
        icon: Building2,
        color: 'text-bantu-orange',
        children: [
          {
            id: 'provider-dashboard',
            title: 'Business Overview',
            icon: BarChart3,
            badge: 'Live',
            description: 'Monitor business performance',
            color: 'text-green-600'
          },
          {
            id: 'client-management',
            title: 'Client Management',
            icon: Users,
            badge: stats.communityConnections,
            path: '/clients',
            description: 'Manage client relationships',
            color: 'text-blue-600'
          },
          {
            id: 'properties',
            title: 'Property Listings',
            icon: Package,
            badge: stats.properties,
            description: 'Manage your property listings',
            color: 'text-purple-600'
          },
          {
            id: 'applications',
            title: 'Applications',
            icon: FileText,
            badge: stats.applications,
            description: 'Track application status',
            color: 'text-orange-600'
          },
          {
            id: 'revenue-analytics',
            title: 'Revenue Analytics',
            icon: TrendingUp,
            badge: stats.totalRevenue > 0 ? `$${(stats.totalRevenue / 1000).toFixed(1)}k` : undefined,
            description: 'Financial insights and trends',
            color: 'text-emerald-600'
          }
        ]
      });
    }

    // Always add settings and notifications at the bottom
    baseItems.push({
      id: 'tools',
      title: 'Account & Settings',
      icon: Settings,
      color: 'text-gray-600',
      children: [
        {
          id: 'notifications',
          title: 'Notifications',
          icon: Bell,
          badge: unreadCount > 0 ? unreadCount : undefined,
          description: 'Manage your notifications',
          color: 'text-red-600'
        },
        {
          id: 'profile',
          title: 'My Profile',
          icon: User,
          path: '/profile',
          description: 'Update account information',
          color: 'text-blue-600'
        },
        {
          id: 'settings',
          title: 'Preferences',
          icon: Settings,
          description: 'Configure dashboard settings',
          color: 'text-gray-600'
        }
      ]
    });

    return baseItems;
  }, [userProfile?.user_type, realTimeData]);

  // Optimized toggle and navigation handlers
  const toggleExpanded = useCallback((itemId: string) => {
    setExpandedItems(prev =>
      prev.includes(itemId)
        ? prev.filter(id => id !== itemId)
        : [...prev, itemId]
    );
  }, []);

  const handleNavigation = useCallback((item: NavigationItem) => {
    if (item.path) {
      navigate(item.path);
    } else if (item.children) {
      toggleExpanded(item.id);
    } else {
      setActiveSection(item.id);
      const newUrl = new URL(window.location.href);
      newUrl.searchParams.set('section', item.id);
      window.history.replaceState(null, '', newUrl.toString());
      // Close mobile menu when navigating
      setMobileMenuOpen(false);
    }
  }, [navigate, toggleExpanded]);

  // Manual refresh handler
  const handleRefresh = useCallback(() => {
    fetchDashboardData(true);
  }, [fetchDashboardData]);

  // Enhanced navigation item renderer with Bantu Stall colors
  const renderNavigationItem = useCallback((item: NavigationItem, depth = 0) => {
    const isActive = activeSection === item.id;
    const isExpanded = expandedItems.includes(item.id);
    const hasChildren = item.children && item.children.length > 0;
    const hasNotifications = item.badge && typeof item.badge === 'number' && item.badge > 0;

    const ItemContent = (
      <Button
        variant={isActive ? "default" : "ghost"}
        size="sm"
        className={`
          w-full justify-start gap-3 h-auto py-3 px-3 text-left transition-all duration-200
          ${depth > 0 ? 'ml-4 border-l-2 border-bantu-orange/20 pl-6' : ''}
          ${isActive 
            ? 'bg-bantu-orange text-white shadow-lg border-bantu-orange' 
            : 'hover:bg-bantu-orange/5 hover:text-bantu-orange border-transparent'
          }
          ${sidebarCollapsed && depth === 0 ? 'px-2 justify-center' : ''}
          font-medium
        `}
        onClick={() => handleNavigation(item)}
      >
        <div className="relative flex-shrink-0">
          <item.icon className={`h-5 w-5 ${item.color || (isActive ? 'text-white' : 'text-bantu-orange')}`} />
          {hasNotifications && (
            <div className="absolute -top-1 -right-1 h-3 w-3 bg-red-500 rounded-full flex items-center justify-center">
              <span className="text-xs text-white font-bold">
                {typeof item.badge === 'number' && item.badge > 9 ? '9+' : item.badge}
              </span>
            </div>
          )}
        </div>
        
        {!sidebarCollapsed && (
          <>
            <div className="flex-1 min-w-0">
              <div className={`font-semibold truncate ${isActive ? 'text-white' : 'text-gray-900'}`}>
                {item.title}
              </div>
              {item.description && depth === 0 && (
                <div className={`text-xs mt-1 line-clamp-1 ${isActive ? 'text-white/80' : 'text-gray-500'}`}>
                  {item.description}
                </div>
              )}
            </div>
            
            <div className="flex items-center gap-2 flex-shrink-0">
              {item.badge && (
                <Badge 
                  variant={isActive ? "secondary" : "outline"} 
                  className={`text-xs px-2 py-0.5 ${
                    isActive 
                      ? 'bg-white/20 text-white border-white/30' 
                      : 'bg-bantu-yellow/10 text-bantu-orange border-bantu-orange/20'
                  }`}
                >
                  {item.badge}
                </Badge>
              )}
              {hasChildren && (
                <ChevronRight 
                  className={`h-4 w-4 transition-transform duration-200 ${
                    isExpanded ? 'rotate-90' : ''
                  } ${isActive ? 'text-white' : 'text-bantu-orange'}`} 
                />
              )}
            </div>
          </>
        )}
      </Button>
    );

    return (
      <div key={item.id} className="mb-1">
        {sidebarCollapsed && depth === 0 ? (
          <TooltipProvider>
            <Tooltip>
              <TooltipTrigger asChild>
                {ItemContent}
              </TooltipTrigger>
              <TooltipContent side="right" className="max-w-xs bg-bantu-orange text-white">
                <div className="font-medium">{item.title}</div>
                {item.description && (
                  <div className="text-xs mt-1 text-white/80">
                    {item.description}
                  </div>
                )}
                {item.badge && (
                  <div className="text-xs mt-1 font-bold">
                    Badge: {item.badge}
                  </div>
                )}
              </TooltipContent>
            </Tooltip>
          </TooltipProvider>
        ) : (
          ItemContent
        )}
        
        {hasChildren && isExpanded && !sidebarCollapsed && (
          <AnimatePresence>
            <motion.div
              initial={{ opacity: 0, height: 0 }}
              animate={{ opacity: 1, height: 'auto' }}
              exit={{ opacity: 0, height: 0 }}
              transition={{ duration: 0.2 }}
              className="mt-1 space-y-1 overflow-hidden ml-2"
            >
              {item.children.map(child => renderNavigationItem(child, depth + 1))}
            </motion.div>
          </AnimatePresence>
        )}
      </div>
    );
  }, [activeSection, expandedItems, handleNavigation, sidebarCollapsed]);

  const renderDashboardContent = () => {
    if (!realTimeData) return <div>Loading...</div>;
    
    switch (activeSection) {
      case 'overview':
        return (
          <OverviewContent 
            userProfile={userProfile} 
            realTimeData={realTimeData}
            onRefresh={handleRefresh}
          />
        );
      case 'explorer':
        return <div>Travel Explorer Content</div>;
      case 'courses':
        return <div>Learning Content</div>;
      case 'members':
        return <div>Community Content</div>;
      case 'retreat-planning':
        return <div>Retreat Planning Content</div>;
      case 'provider-dashboard':
        return <div>Service Provider Content</div>;
      case 'quotations':
        return <div>Quotations Content</div>;
      default:
        return <DefaultSectionContent section={activeSection} />;
    }
  };

  // Enhanced loading state with Bantu Stall branding
  if (realTimeData.isLoading && !refreshing) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-bantu-orange/5 via-white to-bantu-yellow/5">
        <Navbar />
        <div className="flex items-center justify-center min-h-[calc(100vh-5rem)] pt-20">
          <div className="text-center space-y-6">
            <div className="relative">
              <div className="w-20 h-20 border-4 border-bantu-orange/20 rounded-full animate-spin border-t-bantu-orange mx-auto"></div>
              <div className="absolute inset-0 w-16 h-16 border-4 border-bantu-yellow/20 rounded-full animate-ping mx-auto mt-2"></div>
            </div>
            <div className="space-y-2">
              <h3 className="font-bold text-xl text-bantu-orange">Loading Your Dashboard</h3>
              <p className="text-gray-600">Fetching your latest data from Bantu Stall...</p>
              <div className="flex items-center justify-center gap-2">
                <div className="w-2 h-2 bg-bantu-orange rounded-full animate-bounce"></div>
                <div className="w-2 h-2 bg-bantu-yellow rounded-full animate-bounce delay-100"></div>
                <div className="w-2 h-2 bg-bantu-orange rounded-full animate-bounce delay-200"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-bantu-orange/5 via-white to-bantu-yellow/5">
      <Navbar />
      
      {/* Mobile Menu Overlay */}
      {mobileMenuOpen && (
        <div 
          className="fixed inset-0 bg-black/50 z-40 lg:hidden" 
          onClick={() => setMobileMenuOpen(false)}
        />
      )}
      
      <div className="flex pt-20">
        {/* Enhanced Sidebar with Bantu Stall styling */}
        <motion.div
          className={`
            fixed left-0 top-20 h-[calc(100vh-5rem)] z-30
            bg-white/95 backdrop-blur-sm border-r-2 border-bantu-orange/20 shadow-xl
            transition-all duration-300
            ${sidebarCollapsed ? 'w-20' : 'w-80'}
            ${mobileMenuOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'}
          `}
          initial={false}
          animate={{ 
            width: sidebarCollapsed ? 80 : 320,
            transform: mobileMenuOpen ? 'translateX(0)' : 'translateX(-100%)'
          }}
        >
          <div className="flex flex-col h-full bg-gradient-to-b from-white to-bantu-orange/5">
            {/* Enhanced Sidebar Header */}
            <div className="p-4 border-b-2 border-bantu-orange/10 bg-gradient-to-r from-bantu-orange/10 to-bantu-yellow/10">
              <div className="flex items-center justify-between">
                {!sidebarCollapsed && (
                  <motion.div
                    initial={{ opacity: 0 }}
                    animate={{ opacity: 1 }}
                    exit={{ opacity: 0 }}
                    className="space-y-1"
                  >
                    <h2 className="text-xl font-bold text-bantu-orange">Bantu Stall</h2>
                    <p className="text-sm text-gray-600">
                      {userProfile?.user_type ? 
                        `${userProfile.user_type.charAt(0).toUpperCase()}${userProfile.user_type.slice(1).replace('_', ' ')} Dashboard` : 
                        'Welcome Dashboard'
                      }
                    </p>
                  </motion.div>
                )}
                <div className="flex items-center gap-2">
                  {/* Refresh button */}
                  <Button
                    variant="ghost"
                    size="icon"
                    onClick={handleRefresh}
                    disabled={refreshing}
                    className="h-8 w-8 hover:bg-bantu-orange/10 text-bantu-orange"
                  >
                    <RefreshCw className={`h-4 w-4 ${refreshing ? 'animate-spin' : ''}`} />
                  </Button>
                  {/* Mobile close button */}
                  <Button
                    variant="ghost"
                    size="icon"
                    onClick={() => setMobileMenuOpen(false)}
                    className="h-8 w-8 lg:hidden hover:bg-bantu-orange/10 text-bantu-orange"
                  >
                    <X className="h-4 w-4" />
                  </Button>
                  {/* Collapse/expand button */}
                  <Button
                    variant="ghost"
                    size="icon"
                    onClick={() => setSidebarCollapsed(!sidebarCollapsed)}
                    className="h-8 w-8 hover:bg-bantu-orange/10 text-bantu-orange hidden lg:flex"
                  >
                    {sidebarCollapsed ? 
                      <ChevronRight className="h-4 w-4" /> : 
                      <ChevronLeft className="h-4 w-4" />
                    }
                  </Button>
                </div>
              </div>
              
              {/* Last updated indicator */}
              {!sidebarCollapsed && (
                <div className="mt-2 text-xs text-gray-500 flex items-center gap-1">
                  <Clock className="h-3 w-3" />
                  Last updated: {realTimeData.lastUpdated.toLocaleTimeString()}
                  {refreshing && <span className="text-bantu-orange">(Refreshing...)</span>}
                </div>
              )}
            </div>

            {/* Enhanced User Profile Section */}
            {!sidebarCollapsed && (
              <motion.div 
                className="p-4 border-b border-bantu-orange/10 bg-gradient-to-r from-bantu-orange/5 to-transparent"
                initial={{ opacity: 0, y: -10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.1 }}
              >
                <div className="flex items-center gap-3">
                  <Avatar className="h-12 w-12 ring-2 ring-bantu-orange/30 shadow-lg">
                    <AvatarImage src={userProfile?.avatar_url} />
                    <AvatarFallback className="bg-bantu-orange text-white font-bold text-lg">
                      {userProfile?.full_name?.charAt(0) || user?.email?.charAt(0)?.toUpperCase() || 'U'}
                    </AvatarFallback>
                  </Avatar>
                  <div className="flex-1 min-w-0">
                    <p className="font-bold truncate text-gray-900">
                      {userProfile?.full_name || user?.email?.split('@')[0] || 'Welcome'}
                    </p>
                    <p className="text-sm text-bantu-orange font-medium flex items-center gap-1">
                      <div className="h-2 w-2 bg-green-500 rounded-full animate-pulse" />
                      {userProfile?.user_type?.replace('_', ' ') || 'Member'}
                    </p>
                    {userProfile?.company && (
                      <p className="text-xs text-gray-500 truncate">{userProfile.company}</p>
                    )}
                  </div>
                  <Button 
                    variant="ghost" 
                    size="icon" 
                    className="h-8 w-8 hover:bg-bantu-orange/10 text-bantu-orange"
                    onClick={() => navigate('/profile')}
                  >
                    <MoreVertical className="h-4 w-4" />
                  </Button>
                </div>
              </motion.div>
            )}

            {/* Search Bar */}
            {!sidebarCollapsed && (
              <motion.div 
                className="p-4 border-b border-bantu-orange/10"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                transition={{ delay: 0.2 }}
              >
                <div className="relative">
                  <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-bantu-orange/60" />
                  <Input
                    placeholder="Search dashboard..."
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="pl-10 h-10 bg-bantu-orange/5 border-bantu-orange/20 focus:border-bantu-orange focus:ring-bantu-orange/20"
                  />
                </div>
              </motion.div>
            )}

            {/* Enhanced Navigation */}
            <ScrollArea className="flex-1 px-3 py-4">
              <nav className="space-y-2">
                {navigationItems
                  .filter(item => 
                    !searchQuery || 
                    item.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
                    item.children?.some(child => 
                      child.title.toLowerCase().includes(searchQuery.toLowerCase())
                    )
                  )
                  .map(item => renderNavigationItem(item))
                }
              </nav>
            </ScrollArea>

            {/* Enhanced Stats Footer */}
            {!sidebarCollapsed && (
              <motion.div 
                className="p-4 border-t-2 border-bantu-orange/10 bg-gradient-to-r from-bantu-orange/5 to-bantu-yellow/5"
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.3 }}
              >
                <Card className="p-3 bg-gradient-to-br from-bantu-orange/10 to-bantu-yellow/10 border-bantu-orange/20">
                  <div className="grid grid-cols-2 gap-3 text-center">
                    <div className="space-y-1">
                      <div className="text-xl font-bold text-bantu-orange">
                        {realTimeData.stats.activeBookings}
                      </div>
                      <div className="text-xs text-gray-600">Active Bookings</div>
                      <Progress 
                        value={Math.min(100, realTimeData.stats.activeBookings * 10)} 
                        className="h-1"
                      />
                    </div>
                    <div className="space-y-1">
                      <div className="text-xl font-bold text-bantu-yellow">
                        {realTimeData.stats.countriesExplored}
                      </div>
                      <div className="text-xs text-gray-600">Countries</div>
                      <Progress 
                        value={Math.min(100, realTimeData.stats.countriesExplored * 2)} 
                        className="h-1"
                      />
                    </div>
                  </div>
                </Card>
              </motion.div>
            )}
          </div>
        </motion.div>

        {/* Enhanced Main Content Area with mobile menu button */}
        <div className={`flex-1 transition-all duration-300 ${sidebarCollapsed ? 'lg:ml-16' : 'lg:ml-80'}`}>
          {/* Mobile Menu Button */}
          <div className="lg:hidden fixed top-24 left-4 z-20">
            <Button
              variant="outline"
              size="icon"
              onClick={() => setMobileMenuOpen(true)}
              className="h-12 w-12 bg-white shadow-lg border-bantu-orange/20 text-bantu-orange hover:bg-bantu-orange/5"
            >
              <Menu className="h-6 w-6" />
            </Button>
          </div>
          
          <div className="p-6 max-w-7xl mx-auto">
            {/* Enhanced Onboarding Alert */}
            {!userProfile?.onboarding_completed && (
              <motion.div
                initial={{ opacity: 0, y: -20 }}
                animate={{ opacity: 1, y: 0 }}
                className="mb-6"
              >
                <Alert className="border-bantu-orange/30 bg-gradient-to-r from-bantu-orange/10 to-bantu-yellow/10">
                  <Info className="h-5 w-5 text-bantu-orange" />
                  <AlertDescription className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
                    <span className="text-gray-700 font-medium">
                      🚀 Complete your profile setup to unlock personalized recommendations and premium features!
                    </span>
                    <Button 
                      variant="outline" 
                      size="sm" 
                      onClick={() => navigate('/onboarding')}
                      className="shrink-0 border-bantu-orange text-bantu-orange hover:bg-bantu-orange hover:text-white"
                    >
                      Complete Setup
                    </Button>
                  </AlertDescription>
                </Alert>
              </motion.div>
            )}

            {/* Dashboard Content with animations */}
            <motion.div 
              className="space-y-8"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.1 }}
            >
              {renderDashboardContent()}
            </motion.div>
          </div>
        </div>
      </div>

      <Footer />
    </div>
  );
};

// Enhanced Overview Content Component with Bantu Stall colors and real-time data
const OverviewContent: React.FC<{ 
  userProfile: UserProfile | null; 
  realTimeData: RealTimeData;
  onRefresh: () => void;
}> = ({
  userProfile,
  realTimeData,
  onRefresh
}) => {
  const navigate = useNavigate();
  const { stats, recentActivity, notifications } = realTimeData;

  const getPersonalizedGreeting = () => {
    const hour = new Date().getHours();
    const timeGreeting = hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening';
    const userName = userProfile?.full_name?.split(' ')[0] || 'Explorer';
    return `${timeGreeting}, ${userName}!`;
  };

  const getMotivationalMessage = () => {
    const messages = [
      "Ready to explore Africa today? 🌍",
      "Your next adventure is just a click away! ✈️",
      "Discover the magic of Africa with Bantu Stall! 🦁",
      "Let's make today productive and inspiring! 🚀",
      "Connect, explore, and grow with our community! 🤝"
    ];
    return messages[Math.floor(Math.random() * messages.length)];
  };

  const getProgressColor = (value: number) => {
    if (value >= 80) return 'bg-green-500';
    if (value >= 60) return 'bg-bantu-yellow';
    if (value >= 40) return 'bg-bantu-orange';
    return 'bg-red-500';
  };

  return (
    <div className="space-y-8">
      {/* Enhanced Welcome Header with Bantu Stall gradient */}
      <motion.div 
        className="relative overflow-hidden rounded-xl bg-gradient-to-br from-bantu-orange/20 via-bantu-yellow/10 to-white p-8 border-2 border-bantu-orange/20 shadow-lg"
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
      >
        <div className="relative z-10">
          <div className="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4">
            <div className="space-y-3">
              <h1 className="text-4xl lg:text-5xl font-bold tracking-tight text-bantu-orange">
                {getPersonalizedGreeting()}
              </h1>
              <p className="text-xl text-gray-700 font-medium">
                {getMotivationalMessage()}
              </p>
              <p className="text-sm text-gray-600 flex items-center gap-2">
                <span className="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                Welcome back to your Bantu Stall dashboard
              </p>
            </div>
            <div className="text-right space-y-2 bg-white/60 backdrop-blur-sm rounded-lg p-4 border border-bantu-orange/20">
              <div className="text-lg font-bold text-bantu-orange">
                {new Date().toLocaleDateString('en-US', { 
                  weekday: 'long', 
                  month: 'short', 
                  day: 'numeric' 
                })}
              </div>
              <div className="text-sm text-gray-600">
                {new Date().toLocaleTimeString('en-US', { 
                  hour: '2-digit', 
                  minute: '2-digit' 
                })}
              </div>
              <Button
                onClick={onRefresh}
                variant="outline"
                size="sm"
                className="border-bantu-orange text-bantu-orange hover:bg-bantu-orange hover:text-white"
              >
                <RefreshCw className="h-4 w-4 mr-1" />
                Refresh
              </Button>
            </div>
          </div>
        </div>
        {/* Decorative elements */}
        <div className="absolute top-0 right-0 -mt-4 -mr-4 h-32 w-32 rounded-full bg-bantu-orange/10" />
        <div className="absolute bottom-0 left-0 -mb-8 -ml-8 h-40 w-40 rounded-full bg-bantu-yellow/10" />
      </motion.div>

      {/* Real-time Stats Grid with dynamic data */}
      <div className="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            title: "Total Quotations",
            value: stats.totalQuotations,
            change: `${stats.activeBookings} active`,
            icon: FileText,
            color: "text-bantu-orange",
            bgColor: "bg-bantu-orange/10",
            progress: Math.min(100, stats.totalQuotations * 5),
            trending: stats.totalQuotations > 0
          },
          {
            title: "Active Bookings",
            value: stats.activeBookings,
            change: `$${(stats.totalRevenue / 1000).toFixed(1)}k value`,
            icon: Calendar,
            color: "text-green-600",
            bgColor: "bg-green-50",
            progress: Math.min(100, stats.activeBookings * 10),
            trending: stats.activeBookings > 0
          },
          {
            title: "Countries Explored",
            value: stats.countriesExplored,
            change: `${stats.learningProgress}% learning`,
            icon: Globe,
            color: "text-bantu-yellow",
            bgColor: "bg-bantu-yellow/10",
            progress: Math.min(100, stats.countriesExplored * 2),
            trending: stats.countriesExplored > 0
          },
          {
            title: "Community Network",
            value: stats.communityConnections,
            change: `${stats.unreadMessages} new messages`,
            icon: Users,
            color: "text-purple-600",
            bgColor: "bg-purple-50",
            progress: Math.min(100, stats.communityConnections),
            trending: stats.communityConnections > 0
          }
        ].map((stat, index) => (
          <motion.div
            key={stat.title}
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: index * 0.1 }}
          >
            <Card className="hover:shadow-xl transition-all duration-300 cursor-pointer group border-2 hover:border-bantu-orange/30">
              <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
                <CardTitle className="text-sm font-medium text-gray-600">
                  {stat.title}
                </CardTitle>
                <div className={`p-3 rounded-xl ${stat.bgColor} group-hover:scale-110 transition-transform shadow-lg`}>
                  <stat.icon className={`h-5 w-5 ${stat.color}`} />
                </div>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="flex items-center justify-between">
                  <div className={`text-3xl font-bold ${stat.color}`}>
                    {stat.value}
                  </div>
                  {stat.trending && (
                    <TrendingUp className="h-5 w-5 text-green-600" />
                  )}
                </div>
                <div className="space-y-2">
                  <p className="text-xs text-gray-500">{stat.change}</p>
                  <div className="w-full bg-gray-200 rounded-full h-2">
                    <div 
                      className={`h-2 rounded-full transition-all duration-500 ${getProgressColor(stat.progress)}`}
                      style={{ width: `${stat.progress}%` }}
                    />
                  </div>
                </div>
              </CardContent>
            </Card>
          </motion.div>
        ))}
      </div>

      {/* Real-time Activity Section */}
      {recentActivity.length > 0 && (
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.4 }}
        >
          <Card className="overflow-hidden border-2 border-bantu-orange/20">
            <CardHeader className="bg-gradient-to-r from-bantu-orange/10 to-bantu-yellow/10 border-b border-bantu-orange/20">
              <CardTitle className="flex items-center gap-3">
                <Activity className="h-6 w-6 text-bantu-orange" />
                <span className="text-bantu-orange">Recent Activity</span>
                <Badge variant="secondary" className="ml-auto bg-bantu-orange/20 text-bantu-orange">
                  {recentActivity.length} items
                </Badge>
              </CardTitle>
            </CardHeader>
            <CardContent className="p-0">
              <div className="divide-y divide-bantu-orange/10">
                {recentActivity.slice(0, 5).map((activity, index) => (
                  <motion.div 
                    key={activity.id} 
                    className="p-4 hover:bg-bantu-orange/5 transition-colors cursor-pointer"
                    initial={{ opacity: 0, x: -20 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: index * 0.1 }}
                    onClick={() => activity.type === 'quotation' && navigate('/quotations')}
                  >
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-4">
                        <div className="p-2 bg-bantu-orange/10 rounded-lg">
                          <FileText className="h-5 w-5 text-bantu-orange" />
                        </div>
                        <div>
                          <p className="font-semibold text-gray-900">{activity.title}</p>
                          <p className="text-sm text-gray-600">{activity.description}</p>
                          <p className="text-xs text-gray-500 mt-1">
                            {new Date(activity.created_at).toLocaleDateString()} • 
                            {activity.amount && (
                              <span className="font-semibold ml-1 text-green-600">
                                ${activity.amount.toLocaleString()}
                              </span>
                            )}
                          </p>
                        </div>
                      </div>
                      <div className="flex items-center gap-3">
                        <Badge 
                          variant={
                            activity.status === 'approved' || activity.status === 'confirmed' ? 'default' : 
                            activity.status === 'pending' ? 'secondary' : 'outline'
                          }
                          className={`capitalize ${
                            activity.status === 'approved' || activity.status === 'confirmed' 
                              ? 'bg-green-100 text-green-800' 
                              : activity.status === 'pending'
                                ? 'bg-bantu-yellow/20 text-bantu-orange'
                                : ''
                          }`}
                        >
                          {activity.status}
                        </Badge>
                        <ChevronRight className="h-5 w-5 text-gray-400" />
                      </div>
                    </div>
                  </motion.div>
                ))}
              </div>
              {recentActivity.length > 5 && (
                <div className="p-4 border-t bg-bantu-orange/5">
                  <Button 
                    variant="outline" 
                    className="w-full border-bantu-orange text-bantu-orange hover:bg-bantu-orange hover:text-white"
                    onClick={() => navigate('/quotations')}
                  >
                    View All Activity ({recentActivity.length} total)
                    <ChevronRight className="h-4 w-4 ml-2" />
                  </Button>
                </div>
              )}
            </CardContent>
          </Card>
        </motion.div>
      )}

      {/* Dynamic Quick Actions Grid */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.5 }}
      >
        <Card className="border-2 border-bantu-orange/20">
          <CardHeader className="bg-gradient-to-r from-bantu-orange/10 to-bantu-yellow/10">
            <CardTitle className="flex items-center gap-3">
              <Zap className="h-6 w-6 text-bantu-orange" />
              <span className="text-bantu-orange">Quick Actions</span>
            </CardTitle>
          </CardHeader>
          <CardContent className="p-6">
            <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
              {[
                {
                  title: "Request Quote",
                  description: "Get custom service quotes",
                  icon: Plus,
                  onClick: () => navigate('/quotations'),
                  color: "bg-bantu-orange hover:bg-bantu-orange/90 text-white",
                  count: stats.totalQuotations
                },
                {
                  title: "Explore Countries",
                  description: "Discover African destinations",
                  icon: Globe,
                  onClick: () => navigate('/countries'),
                  color: "bg-green-600 hover:bg-green-700 text-white",
                  count: stats.countriesExplored
                },
                {
                  title: "Update Profile",
                  description: "Manage your account",
                  icon: User,
                  onClick: () => navigate('/profile'),
                  color: "bg-blue-600 hover:bg-blue-700 text-white",
                  count: null
                },
                {
                  title: "Join Community",
                  description: "Connect with travelers",
                  icon: Users,
                  onClick: () => navigate('/abantu'),
                  color: "bg-purple-600 hover:bg-purple-700 text-white",
                  count: stats.communityConnections
                }
              ].map((action, index) => (
                <motion.div
                  key={action.title}
                  whileHover={{ scale: 1.02 }}
                  whileTap={{ scale: 0.98 }}
                  className="relative"
                >
                  <Button 
                    className={`h-auto p-6 flex flex-col gap-3 w-full ${action.color} shadow-lg hover:shadow-xl transition-all`}
                    onClick={action.onClick}
                  >
                    <action.icon className="h-8 w-8" />
                    <div className="text-center">
                      <div className="font-bold text-lg">{action.title}</div>
                      <div className="text-xs opacity-90 mt-1">{action.description}</div>
                    </div>
                    {action.count !== null && action.count > 0 && (
                      <Badge className="absolute -top-2 -right-2 bg-bantu-yellow text-bantu-orange">
                        {action.count}
                      </Badge>
                    )}
                  </Button>
                </motion.div>
              ))}
            </div>
          </CardContent>
        </Card>
      </motion.div>

      {/* Notifications Overview */}
      {notifications.length > 0 && (
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.6 }}
        >
          <Card className="border-2 border-bantu-orange/20">
            <CardHeader className="bg-gradient-to-r from-bantu-orange/10 to-bantu-yellow/10">
              <CardTitle className="flex items-center gap-3">
                <Bell className="h-6 w-6 text-bantu-orange" />
                <span className="text-bantu-orange">Latest Notifications</span>
                <Badge className="ml-auto bg-red-100 text-red-800">
                  {notifications.filter(n => !n.read).length} unread
                </Badge>
              </CardTitle>
            </CardHeader>
            <CardContent className="p-4">
              <div className="space-y-3">
                {notifications.slice(0, 3).map((notification, index) => (
                  <div 
                    key={notification.id}
                    className={`p-3 rounded-lg border ${
                      !notification.read 
                        ? 'bg-bantu-orange/5 border-bantu-orange/20' 
                        : 'bg-gray-50 border-gray-200'
                    }`}
                  >
                    <div className="flex items-start gap-3">
                      <Bell className={`h-4 w-4 mt-1 ${!notification.read ? 'text-bantu-orange' : 'text-gray-400'}`} />
                      <div className="flex-1">
                        <p className="font-medium text-sm">{notification.title}</p>
                        <p className="text-xs text-gray-600 mt-1">{notification.message}</p>
                        <p className="text-xs text-gray-500 mt-2">
                          {new Date(notification.created_at).toLocaleString()}
                        </p>
                      </div>
                      {!notification.read && (
                        <div className="w-2 h-2 bg-bantu-orange rounded-full" />
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        </motion.div>
      )}
    </div>
  );
};

// Default Section Content for sections that don't have dedicated components
const DefaultSectionContent: React.FC<{ section: string }> = ({ section }) => {
  return (
    <div className="text-center py-20">
      <div className="mx-auto max-w-md">
        <Sparkles className="mx-auto h-12 w-12 text-muted-foreground mb-4" />
        <h3 className="text-lg font-semibold mb-2">Coming Soon</h3>
        <p className="text-muted-foreground">
          The {section} section is being developed and will be available soon.
        </p>
      </div>
    </div>
  );
};

export default CentralizedDashboard;
